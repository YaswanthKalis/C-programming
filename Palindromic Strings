#include <stdio.h>
#include <string.h>
int main() 
{
    char s[100], r[100];
    int i, j = 0;
    scanf("%s", s);

    for(i = strlen(s)-1; i >= 0; i--)
        r[j] = s[i];
        j++;
        r[j] = '\0';

if(strcmp(s, r) == 0)
       {
        printf("Palindrome");
       }
 else
       {
        printf("Not Palindrome");
       }

    return 0;
}
